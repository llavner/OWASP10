root = true

############################################
# Global / Files
############################################

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

############################################
# Non-C# files (keep diffs clean)
############################################

[*.{sln,csproj,props,targets,json,yml,yaml,md}]
indent_style = space
indent_size = 2

############################################
# C# base formatting
############################################

[*.cs]
indent_style = space
indent_size = 4
tab_width = 4

############################################
# Using directives
############################################

[*.cs]
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_using_directive_placement = outside_namespace

############################################
# Namespace style (prefer modern, consistent)
############################################

[*.cs]
csharp_style_namespace_declarations = file_scoped:warning
dotnet_style_namespace_match_folder = true:suggestion

############################################
# "this." qualification (prefer no)
############################################

[*.cs]
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

############################################
# Type style: keywords vs BCL types
############################################

[*.cs]
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

############################################
# Accessibility modifiers
############################################

[*.cs]
# Good baseline: require access modifiers for non-interface members
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion

############################################
# var preferences (keep consistent; low noise)
############################################

[*.cs]
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

############################################
# Braces & newlines (high-signal)
############################################

[*.cs]
csharp_prefer_braces = true:warning
csharp_new_line_before_open_brace = all

############################################
# Expression-bodied members (conservative)
############################################

[*.cs]
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
# Keep the rest default/unspecified to reduce churn:
# constructors, operators, local functions, etc.

############################################
# Pattern matching / modern C#
############################################

[*.cs]
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_prefer_extended_property_pattern = true:suggestion

############################################
# Null-checking preferences
############################################

[*.cs]
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
csharp_style_throw_expression = true:suggestion

############################################
# Parentheses preferences (keep readable)
############################################

[*.cs]
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:suggestion

############################################
# IDE analyzers (tune for warnings-as-errors repos)
############################################

[*.cs]
dotnet_diagnostic.IDE0005.severity = warning  # Remove unused usings
dotnet_diagnostic.IDE0051.severity = warning  # Remove unused private member
dotnet_diagnostic.IDE0060.severity = warning  # Remove unused parameter
dotnet_diagnostic.IDE0161.severity = warning  # Convert to file-scoped namespace

############################################
# Code quality analyzers (CA*) - select high-signal
############################################

[*.cs]
dotnet_diagnostic.CA1849.severity = warning     # Call async methods when available
dotnet_diagnostic.CA2007.severity = suggestion  # Consider ConfigureAwait

############################################
# Naming rules (minimal, consistent)
############################################

# Private fields: _camelCase
dotnet_naming_rule.private_fields_should_be_underscore_camel.severity = suggestion
dotnet_naming_rule.private_fields_should_be_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_underscore_camel.style = underscore_camel

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.required_suffix =
dotnet_naming_style.underscore_camel.word_separator =
dotnet_naming_style.underscore_camel.capitalization = camel_case

# Interfaces: IName
dotnet_naming_rule.interfaces_should_be_i_prefixed.severity = suggestion
dotnet_naming_rule.interfaces_should_be_i_prefixed.symbols = interfaces
dotnet_naming_rule.interfaces_should_be_i_prefixed.style = i_prefixed

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.interfaces.required_modifiers =

dotnet_naming_style.i_prefixed.required_prefix = I
dotnet_naming_style.i_prefixed.required_suffix =
dotnet_naming_style.i_prefixed.word_separator =
dotnet_naming_style.i_prefixed.capitalization = pascal_case

# Types: PascalCase
dotnet_naming_rule.types_should_be_pascal.severity = suggestion
dotnet_naming_rule.types_should_be_pascal.symbols = types
dotnet_naming_rule.types_should_be_pascal.style = pascal

dotnet_naming_symbols.types.applicable_kinds = class, struct, record, enum, interface
dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.types.required_modifiers =

dotnet_naming_style.pascal.required_prefix =
dotnet_naming_style.pascal.required_suffix =
dotnet_naming_style.pascal.word_separator =
dotnet_naming_style.pascal.capitalization = pascal_case

############################################
# StyleCop.Analyzers baseline (avoid busywork early)
############################################

[*.cs]
# Disable XML doc requirement initially (turn on later if you want)
dotnet_diagnostic.SA0001.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1602.severity = none

# Using/order/layout (keep as suggestions; formatter + IDE will fix)
dotnet_diagnostic.SA1200.severity = suggestion
dotnet_diagnostic.SA1201.severity = suggestion
dotnet_diagnostic.SA1210.severity = suggestion

# Spacing/readability (suggestion)
dotnet_diagnostic.SA1000.severity = suggestion
dotnet_diagnostic.SA1001.severity = suggestion
dotnet_diagnostic.SA1005.severity = suggestion

# File header requirements (off)
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1636.severity = none

############################################
# Tests (uncomment once you add a tests/ folder)
############################################
# [tests/**/*.cs]
# dotnet_diagnostic.CA1707.severity = none
# dotnet_diagnostic.SA1300.severity = none
