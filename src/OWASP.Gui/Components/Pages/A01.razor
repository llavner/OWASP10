@page "/a01"
@using MudBlazor

<section class="lp-band lp-hero">
    <MudContainer MaxWidth="MaxWidth.Large" Gutters="false" Class="lp-section-lg">
        <MudText Typo="Typo.h3" GutterBottom Class="lp-on-dark">
            A01 – Broken Access Control
        </MudText>
        <MudText Typo="Typo.h6" Class="lp-on-dark-muted">
            När auktorisering saknas eller implementeras fel – t.ex. IDOR (Object-level authorization) där användare kan läsa andras data
            genom att manipulera parametrar i URL:en.
        </MudText>
    </MudContainer>
</section>

<MudContainer MaxWidth="MaxWidth.Large" Gutters="false" Class="lp-section">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Elevation="1" Class="pa-6 lp-rounded">
                <MudText Typo="Typo.h5" GutterBottom>Sammanfattning</MudText>

                <MudText Typo="Typo.body1" Paragraph="true">
                    I demon visas en sårbar implementation där endpointen <code>/api/vulnerable/orders/{orderId}</code>
                    kräver autentisering, men saknar objekt-nivå behörighetskontroll. Det innebär att applikationen inte
                    verifierar att den inloggade användaren faktiskt äger ordern som hämtas.
                </MudText>

                <MudText Typo="Typo.body1">
                    Resultatet blir en IDOR-sårbarhet: en användare kan ändra <code>orderId</code> i URL:en och läsa andra
                    användares orderdata.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="1" Class="pa-6 lp-rounded">
                <MudText Typo="Typo.h6" GutterBottom>Riskbedömning</MudText>

                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2"><b>Sannolikhet:</b> Hög</MudText>
                    <MudText Typo="Typo.body2"><b>Konsekvens:</b> Hög</MudText>
                </MudStack>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    URL-parametrar är enkla att manipulera och felet uppstår ofta när servern “litar” på att klienten bara frågar efter egna ID:n.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudCard Class="lp-rounded">
                <MudCardContent Class="pa-6">
                    <MudText Typo="Typo.h6" GutterBottom>Åtgärd (fix)</MudText>

                    <MudText Typo="Typo.body1" Paragraph="true">
                        I <code>/api/fixed/orders/{orderId}</code> görs en ägarskapskontroll genom att jämföra orderns
                        <code>UserId</code> med aktuell användare (t.ex. från <code>ClaimTypes.NameIdentifier</code>).
                        Vid mismatch returneras <b>403 Forbidden</b> (alternativt <b>404 NotFound</b> för att inte avslöja objektets existens).
                    </MudText>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.h6" GutterBottom>Evidence (test/bevis)</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem>
                            <b>Vulnerable:</b> <code>user-a</code> kan läsa <code>user-b</code>:s order via <code>/api/vulnerable/orders/102</code> (HTTP 200).
                        </MudListItem>
                        <MudListItem>
                            <b>Fixed:</b> samma anrop mot <code>/api/fixed/orders/102</code> ger <b>403</b> (eller <b>404</b>).
                        </MudListItem>
                        <MudListItem>
                            (Valfritt) Rätt användare mot fixed endpoint får <b>200 OK</b>.
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-6 lp-rounded">
                <MudText Typo="Typo.h6" GutterBottom>Verkligt exempel</MudText>
                <MudText Typo="Typo.body1">
                    <b>Peloton (2021)</b> rapporterades ha ett API-problem som kunde exponera privata användaruppgifter när
                    åtkomstkontrollen inte tillräckligt begränsade vem som fick hämta vilken data. Det är samma typ av risk
                    som i demon: när servern inte gör korrekt resurs-ägarskapskontroll kan data exponeras mellan användare.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
